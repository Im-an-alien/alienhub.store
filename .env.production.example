# Copy to ".env" on the VM (next to docker-compose.prod.yml) and fill in.
#   cp .env.production.example .env   then edit .env

# Database password (used by both the db and the app)
DB_PASSWORD=change-this-strong-password

# Admin session signing secret. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=change-this-to-a-long-random-string

# Optional: Telegram order notifications (leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
