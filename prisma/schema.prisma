// AlienHub.Store — data model
// Storefront catalog + COD orders + ported back-office (inventory/profit) data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Catalog ────────────────────────────────────────────────────────────────

enum WebStatus {
  AVAILABLE
  COMING_SOON
  HIDDEN
}

model Category {
  id        String    @id @default(cuid())
  name      String // e.g. "Targeting Device"
  slug      String    @unique
  code      String    @unique // unit-ID class code, e.g. "TD"
  typeLabel String? // original simple type, e.g. "Mouse"
  imageUrl  String?
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id          String           @id @default(cuid())
  sku         String           @unique
  name        String
  slug        String           @unique
  brand       String?
  supplier    String?
  description  String?
  basePrice   Int // IQD, no decimals
  cost        Int              @default(0) // unit cost (COGS reference), admin-only
  unitId      String? // e.g. AH-TD-0007
  webStatus   WebStatus        @default(AVAILABLE)
  isFeatured  Boolean          @default(false)
  isBundle    Boolean          @default(false)
  categoryId  String?
  category    Category?        @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]
  images      ProductImage[]
  specs       ProductSpec[]
  orderItems  OrderItem[]
  inquiries   Inquiry[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([categoryId])
  @@index([webStatus])
}

// Every product has >= 1 variant; stock lives here.
model ProductVariant {
  id             String         @id @default(cuid())
  productId      String
  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  name           String         @default("Default") // e.g. "Pink", "TKL"
  skuSuffix      String? // appended to product.sku for the full variant SKU
  priceOverride  Int? // if null, use product.basePrice
  stockQty       Int            @default(0)
  totalPurchased Int            @default(0)
  totalSold      Int            @default(0)
  images         ProductImage[]
  orderItems     OrderItem[]
  isDefault      Boolean        @default(false)

  @@index([productId])
}

model ProductImage {
  id        String          @id @default(cuid())
  productId String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  url       String
  altText   String?
  isPrimary Boolean         @default(false)
  sortOrder Int             @default(0)

  @@index([productId])
}

model ProductSpec {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  specKey   String // e.g. "Switch Type"
  specValue String // e.g. "Blue Mechanical"
  sortOrder Int     @default(0)

  @@index([productId])
}

// ─── Orders (Cash on Delivery) ──────────────────────────────────────────────

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique // e.g. ORD-007
  customerName String
  phone        String
  address      String
  city         String
  notes        String?
  status       OrderStatus @default(PENDING)
  subtotal     Int
  deliveryFee  Int         @default(5000)
  total        Int
  channel      String      @default("Website")
  payment      String      @default("Cash (COD)")
  adminNotes   String?
  items        OrderItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([status])
  @@index([phone])
}

model OrderItem {
  id           String          @id @default(cuid())
  orderId      String
  order        Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId    String?
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  productName  String // snapshot
  variantName  String?
  qty          Int             @default(1)
  unitPrice    Int
  cogsSnapshot Int             @default(0)

  @@index([orderId])
}

// ─── Leads / money / admin ──────────────────────────────────────────────────

enum InquiryType {
  NOTIFY // "Notify me" on a coming-soon product
  CONTACT // general contact form
}

model Inquiry {
  id        String      @id @default(cuid())
  productId String?
  product   Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  name      String
  phone     String
  message   String?
  type      InquiryType @default(CONTACT)
  isRead    Boolean     @default(false)
  createdAt DateTime    @default(now())

  @@index([isRead])
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime
  category    String
  description String   @default("")
  amount      Int
  notes       String   @default("")
  createdAt   DateTime @default(now())
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}
